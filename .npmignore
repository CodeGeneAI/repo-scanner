# Test and fixture files (not needed at runtime)
**/*.unit.test.ts
**/*.unit.test.tsx
**/*.unit.spec.ts
**/*.unit.spec.tsx
**/*.test.helpers.ts
**/__fixtures__/
**/__snapshots__/

# Build artifacts and caches
dist/
tsconfig.json
tsconfig.tsbuildinfo
.turbo/
node_modules/
coverage/
.cache/

# Editor / OS cruft
.DS_Store
*.log

# Repo tooling / CI / release infra (not useful to consumers)
.github/
.release-please-config.json
.release-please-manifest.json
bun.lock
.gitignore
.npmignore
.agents/
.codex/
docs/

# Agent / workspace guidance (not useful to consumers)
AGENTS.md
CLAUDE.md

# Local scan/lint configs
.scanignore
biome.json
