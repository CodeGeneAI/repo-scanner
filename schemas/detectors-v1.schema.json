{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assets.codegene.ai/binaries/repo-scanner/schemas/detectors-v1.schema.json",
  "title": "repo-scanner detector catalog schema (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "version", "detectors", "presets"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://assets.codegene.ai/binaries/repo-scanner/schemas/detectors-v1.schema.json"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "detectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "presets": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "uniqueItems": true
      }
    }
  }
}
