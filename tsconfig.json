{
  "extends": "@codegeneai/typescript-config/base",
  "compilerOptions": {
    "target": "ESNext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["bun"]
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": [
    "**/node_modules",
    "dist",
    "coverage",
    "src/code-duplication/__fixtures__"
  ]
}
